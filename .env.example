# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ─── Tripadvisor16 RapidAPI (flights + hotels — primary data source) ─────────
# Subscribe at https://rapidapi.com/apiheya/api/tripadvisor16
# Free tier ≈ 500 requests/month; the route layer caps usage at 500 calls / 24h.
RAPIDAPI_KEY=

# ─── Anthropic Claude (AI itinerary, visa, road-trip, deals) ────────────────
# Get a key from https://console.anthropic.com
# Used by /api/ai/plan-trip + /api/ai/visa-check + /api/deals/from/[iata]
# + /api/road-trip/plan. Routes fall back to template content if missing.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Groq (live chat agent — free tier) ─────────────────────────────────────
# Create a key at https://console.groq.com/keys
# Used by /api/chat for the Ask AI assistant (Llama 3.3 70B Versatile).
# Free tier: ~30 requests/min — sufficient for moderate concurrent chat use.
GROQ_API_KEY=

# ─── Google Maps (Embed API for trip detail route map) ──────────────────────
# Used client-side for the interactive route map iframe on /plan/trip/[id]/map
# and /road-trip/result/[id]/map. Restrict the key by HTTP referrer in
# Google Cloud Console (e.g. https://*.travel-twin.vercel.app/*).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Google Maps Server Key (Directions + Distance Matrix + Geocoding) ──────
# REQUIRED for the structured transit sidebar on /plan/trip/[id]/map AND for
# the /road-trip planner (distance/duration on land, city geocoding, places).
#
# Must be a SEPARATE key from NEXT_PUBLIC_GOOGLE_MAPS_API_KEY:
#   - The public key has HTTP referer restrictions (correct for the iframe
#     Embed API rendered client-side).
#   - Google's Directions API REJECTS any key with HTTP referer restrictions
#     on server-to-server calls.
#
# One-time setup (~3 minutes):
#   1. https://console.cloud.google.com/apis/credentials → "Create credentials"
#   2. Restrict key to APIs: Directions, Distance Matrix, Geocoding, Places
#   3. Application restrictions → "None" (or Vercel egress IPs)
#   4. Enable the 4 APIs in Google Cloud Console
#
# Cost: ~$5 per 1000 requests. Cached 24h (drive) / 30 days (geocoding).
# Without this key the transit tab shows a "View in Google Maps" fallback —
# no crash, no broken UI.
GOOGLE_MAPS_SERVER_API_KEY=

# ─── Unsplash (destination hero images) ──────────────────────────────────────
# Optional — public photo IDs are used directly without an access key for the
# default case. Required only if you call /api/unsplash dynamically.
UNSPLASH_ACCESS_KEY=

# ─── Pexels (destination video shorts on /api/videos/[city]) ────────────────
# Get a free key at https://www.pexels.com/api/
# Falls back to empty results with a console.warn if missing.
PEXELS_API_KEY=
