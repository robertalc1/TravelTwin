# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service-role key (server-only, never expose). Used by cron jobs that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ─── Amadeus GDS (flights + hotels) ──────────────────────────────────────────
# Self-service: https://developers.amadeus.com/register (free tier OK for thesis)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Optional override: 'test' or 'production' (default 'test' for free tier)
AMADEUS_HOSTNAME=test

# ─── Anthropic Claude (AI itinerary, chat, visa) ─────────────────────────────
# Get a key from https://console.anthropic.com
# Optional: routes that need it gracefully fall back to template content.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google OAuth (public Client ID only) ────────────────────────────────────
# The Client Secret lives in Supabase Dashboard → Authentication → Providers,
# never in code or .env. Add the corresponding callback URL in Supabase under
# Authentication → URL Configuration → Redirect URLs:
#   https://travel-twin.vercel.app/auth/callback
#   http://localhost:3000/auth/callback   (only if testing OAuth locally)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Unsplash (destination hero images) ──────────────────────────────────────
# Optional — public photo IDs are used directly without an access key.
UNSPLASH_ACCESS_KEY=

# ─── Mapbox (geocoding cache, optional upgrade from Nominatim) ──────────────
# Free tier: 100,000 requests/month. Required only for the future Mapbox path.
MAPBOX_TOKEN=

# ─── Cron security (used by /api/cron/* routes) ──────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Web Push (price-drop notifications, future feature) ────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Email (booking confirmations, alerts) ───────────────────────────────────
# Optional — falls back to console.log when missing. https://resend.com
RESEND_API_KEY=

# ─── Observability (production only) ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Rate limiting (production only) ─────────────────────────────────────────
# Free Upstash Redis: https://upstash.com → 10k commands/day
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
