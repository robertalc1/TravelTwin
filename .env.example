# ─── Supabase ────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service-role key (server-only, never expose). Used by cron jobs that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ─── Tripadvisor16 RapidAPI (flights + hotels — primary data source) ─────────
# Subscribe at https://rapidapi.com/apiheya/api/tripadvisor16
# Free tier ≈ 500 requests/month; the route layer caps usage at 100 calls / 24h.
RAPIDAPI_KEY=

# ─── Anthropic Claude (AI itinerary, visa) ───────────────────────────────────
# Get a key from https://console.anthropic.com
# Used by /api/ai/plan-trip + /api/ai/visa-check + /api/deals/from/[iata].
# Routes fall back to template content if missing.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Groq (live chat agent — free tier, no auto-disable on leak) ─────────────
# Create a key at https://console.groq.com/keys
# Used by /api/chat for the Ask AI assistant (Llama 3.3 70B Versatile).
# Free tier: ~30 requests/min — sufficient for moderate concurrent chat use.
GROQ_API_KEY=

# ─── Google OAuth (public Client ID only) ────────────────────────────────────
# The Client Secret lives in Supabase Dashboard → Authentication → Providers,
# never in code or .env. Add the corresponding callback URL in Supabase under
# Authentication → URL Configuration → Redirect URLs:
#   https://travel-twin.vercel.app/auth/callback
#   http://localhost:3000/auth/callback   (only if testing OAuth locally)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Facebook OAuth (public App ID only) ─────────────────────────────────────
# The App Secret lives in Supabase Dashboard → Authentication → Providers,
# never in code or .env. The same callback URL applies as Google.
NEXT_PUBLIC_FACEBOOK_APP_ID=

# ─── Unsplash (destination hero images) ──────────────────────────────────────
# Optional — public photo IDs are used directly without an access key.
UNSPLASH_ACCESS_KEY=

# ─── Mapbox (geocoding cache, optional upgrade from Nominatim) ──────────────
# Free tier: 100,000 requests/month. Required only for the future Mapbox path.
MAPBOX_TOKEN=

# ─── Google Maps (Embed API for trip detail route map) ──────────────────────
# Required only for the interactive route map on /plan/trip/[id].
# Embed API is FREE and unlimited even with key — does NOT count against the
# $200/month JavaScript Maps quota. Restrict the key by HTTP referrer in
# Google Cloud Console (e.g. https://*.travel-twin.vercel.app/*).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Google Maps Server Key (Directions + Distance Matrix + Geocoding) ──────
# REQUIRED to power the structured transit sidebar on /plan/trip/[id]/map
# AND the /road-trip planner (distance/duration on land, city geocoding).
#
# Must be a SEPARATE key from NEXT_PUBLIC_GOOGLE_MAPS_API_KEY because:
#   - The public key above has HTTP referer restrictions (correct for the
#     iframe Embed API rendered client-side).
#   - Google's Directions API REJECTS any key with HTTP referer restrictions
#     on server-to-server calls (Vercel functions hitting Google).
#   - Mixing them = error "API keys with referer restrictions cannot be used
#     with this API" and the transit panel shows the fallback card.
#
# One-time setup (~3 minutes):
#   1. https://console.cloud.google.com/apis/credentials → "Create credentials"
#      → "API key"
#   2. Click the new key → "API restrictions" → "Restrict key" → select:
#      "Directions API", "Distance Matrix API", "Geocoding API"
#   3. "Application restrictions" → "None" (recommended for Vercel) OR
#      "IP addresses" with Vercel's egress IPs
#   4. Enable all three APIs in Google Cloud Console:
#      - https://console.cloud.google.com/apis/library/directions-backend.googleapis.com
#      - https://console.cloud.google.com/apis/library/distance-matrix-backend.googleapis.com
#      - https://console.cloud.google.com/apis/library/geocoding-backend.googleapis.com
#   5. Copy the key value into this env var (locally + Vercel Project Settings
#      → Environment Variables, scope: Production + Preview + Development).
#
# Cost: ~$5 per 1000 requests, cached 6h per (origin, destination, mode).
# Without this key the transit tab shows a friendly "View in Google Maps"
# fallback — no crash, no broken UI.
GOOGLE_MAPS_SERVER_API_KEY=

# ─── Cron security (used by /api/cron/* routes) ──────────────────────────────
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Web Push (price-drop notifications, future feature) ────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Email (booking confirmations, alerts) ───────────────────────────────────
# Optional — falls back to console.log when missing. https://resend.com
RESEND_API_KEY=

# ─── Observability (production only) ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Rate limiting (production only) ─────────────────────────────────────────
# Free Upstash Redis: https://upstash.com → 10k commands/day
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
